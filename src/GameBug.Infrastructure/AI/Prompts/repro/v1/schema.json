{
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Descriptive title of the reproduction case"
    },
    "buildVersion": {
      "type": "string",
      "description": "Normalized build version or 'Unknown'"
    },
    "platform": {
      "type": "string",
      "description": "Target platform or 'Unknown'"
    },
    "preconditions": {
      "type": "string",
      "description": "List of preconditions required to set up the repro"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "order": {
            "type": "integer"
          },
          "description": {
            "type": "string"
          },
          "stepType": {
            "type": "string",
            "enum": [
              "Confirmed",
              "SuggestedToVerify"
            ]
          },
          "sourceId": {
            "type": ["string", "null"],
            "description": "The GUID of the evidence source if Confirmed, or null"
          },
          "inferenceReason": {
            "type": ["string", "null"],
            "description": "The logic or reason if SuggestedToVerify, or null"
          }
        },
        "required": [
          "order",
          "description",
          "stepType",
          "sourceId",
          "inferenceReason"
        ],
        "additionalProperties": false
      }
    },
    "expectedResult": {
      "type": "string"
    },
    "actualResult": {
      "type": "string"
    },
    "severityEstimate": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    "severityReason": {
      "type": "string"
    },
    "missingInformation": {
      "type": "string"
    },
    "confidence": {
      "type": "number"
    }
  },
  "required": [
    "title",
    "buildVersion",
    "platform",
    "preconditions",
    "steps",
    "expectedResult",
    "actualResult",
    "severityEstimate",
    "severityReason",
    "missingInformation",
    "confidence"
  ],
  "additionalProperties": false
}
