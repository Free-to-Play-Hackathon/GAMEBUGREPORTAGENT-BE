# Copy this file to .env and fill in your own local values.
# .env is ignored by git, so every developer keeps their own secrets locally.

Ai__OpenAI__ApiKey=your-openai-api-key
Ai__OpenAI__BaseUrl=https://api.openai.com/v1
Ai__Routes__ReportUnderstanding__Model=gpt-4.1
Ai__Routes__ReproSynthesis__Model=gpt-4.1
